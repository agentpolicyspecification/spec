{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentpolicyspecification.github.io/schemas/v0.1.0/policy-set.schema.json",
  "title": "PolicySet",
  "description": "A policy set targeting a specific policy engine and execution transport. The `type` field selects the engine; `transport` and `source` configure how the policy is loaded/evaluated. Inline DSL rules are provided via `policies` (only valid for type 'dsl').",
  "allOf": [{ "$ref": "./base.schema.json" }],
  "type": "object",
  "required": ["aps_version", "type"],
  "additionalProperties": false,
  "properties": {
    "aps_version": {
      "type": "string",
      "description": "The APS specification version this policy set targets (e.g. '0.1.0').",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "type": {
      "$ref": "./base.schema.json#/$defs/PolicyType"
    },
    "transport": {
      "$ref": "./base.schema.json#/$defs/Transport"
    },
    "source": {
      "$ref": "#/$defs/PolicySource"
    },
    "policies": {
      "type": "array",
      "description": "Inline DSL policy rules. Only valid when type is 'dsl'.",
      "items": { "$ref": "#/$defs/PolicyEntry" }
    }
  },
  "allOf": [
    {
      "description": "DSL type: requires inline policies array; transport must be 'file' (default) or 'http' (non-standard).",
      "if": { "properties": { "type": { "const": "dsl" } } },
      "then": {
        "required": ["policies"],
        "properties": {
          "transport": { "enum": ["file", "http"] }
        }
      }
    },
    {
      "description": "Rego type: requires source and transport; transport restricted to file, http, or wasm.",
      "if": { "properties": { "type": { "const": "rego" } } },
      "then": {
        "required": ["transport", "source"],
        "properties": {
          "transport": { "enum": ["file", "http", "wasm"] }
        }
      }
    },
    {
      "description": "Cedar type: requires source and transport; transport restricted to file or http.",
      "if": { "properties": { "type": { "const": "cedar" } } },
      "then": {
        "required": ["transport", "source"],
        "properties": {
          "transport": { "enum": ["file", "http"] }
        }
      }
    },
    {
      "description": "CEL type: requires source; only file transport is supported.",
      "if": { "properties": { "type": { "const": "cel" } } },
      "then": {
        "required": ["transport", "source"],
        "properties": {
          "transport": { "const": "file" }
        }
      }
    },
    {
      "description": "Casbin type: requires source; only file transport is supported.",
      "if": { "properties": { "type": { "const": "casbin" } } },
      "then": {
        "required": ["transport", "source"],
        "properties": {
          "transport": { "const": "file" }
        }
      }
    },
    {
      "description": "LLM type: requires source; only http transport is supported (remote by nature).",
      "if": { "properties": { "type": { "const": "llm" } } },
      "then": {
        "required": ["transport", "source"],
        "properties": {
          "transport": { "const": "http" }
        }
      }
    },
    {
      "description": "Runtime type: always in-process; transport must be 'runtime' and source must be a RuntimeSource.",
      "if": { "properties": { "type": { "const": "runtime" } } },
      "then": {
        "required": ["transport", "source"],
        "properties": {
          "transport": { "const": "runtime" },
          "source": { "$ref": "./base.schema.json#/$defs/RuntimeSource" }
        }
      }
    },
    {
      "description": "File transport requires a FileSource.",
      "if": { "properties": { "transport": { "const": "file" } } },
      "then": {
        "properties": {
          "source": { "$ref": "./base.schema.json#/$defs/FileSource" }
        }
      }
    },
    {
      "description": "HTTP transport requires an HttpSource.",
      "if": { "properties": { "transport": { "const": "http" } } },
      "then": {
        "properties": {
          "source": { "$ref": "./base.schema.json#/$defs/HttpSource" }
        }
      }
    },
    {
      "description": "Wasm transport requires a WasmSource.",
      "if": { "properties": { "transport": { "const": "wasm" } } },
      "then": {
        "properties": {
          "source": { "$ref": "./base.schema.json#/$defs/WasmSource" }
        }
      }
    },
    {
      "description": "Stdio transport requires a StdioSource.",
      "if": { "properties": { "transport": { "const": "stdio" } } },
      "then": {
        "properties": {
          "source": { "$ref": "./base.schema.json#/$defs/StdioSource" }
        }
      }
    }
  ],
  "$defs": {
    "PolicySource": {
      "description": "Source configuration for loading or reaching the policy evaluator. The required shape is determined by the transport field.",
      "oneOf": [
        { "$ref": "./base.schema.json#/$defs/FileSource" },
        { "$ref": "./base.schema.json#/$defs/HttpSource" },
        { "$ref": "./base.schema.json#/$defs/WasmSource" },
        { "$ref": "./base.schema.json#/$defs/StdioSource" },
        { "$ref": "./base.schema.json#/$defs/RuntimeSource" }
      ]
    },
    "PolicyEntry": {
      "title": "PolicyEntry",
      "description": "A DSL policy rule with optional scope restrictions. Only used when type is 'dsl'.",
      "type": "object",
      "required": ["condition", "action"],
      "additionalProperties": false,
      "properties": {
        "condition": {
          "$ref": "#/$defs/Condition"
        },
        "action": {
          "type": "string",
          "enum": ["allow", "deny", "redact", "transform", "audit"],
          "description": "The action to take when the condition matches"
        },
        "reason": {
          "type": "string",
          "description": "Optional human-readable reason, typically used with deny"
        },
        "redactions": {
          "type": "array",
          "description": "Redaction instructions to apply when action is 'redact'.",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["field", "strategy"],
            "additionalProperties": false,
            "properties": {
              "field": {
                "type": "string",
                "description": "Dot-notation path to the field being redacted (e.g. 'response.content')."
              },
              "strategy": {
                "type": "string",
                "enum": ["mask", "remove", "replace"],
                "description": "'mask' replaces with a fixed string, 'remove' deletes the field, 'replace' substitutes matched patterns."
              },
              "replacement": {
                "type": "string",
                "description": "Replacement string. Required when strategy is 'mask' or 'replace'."
              },
              "pattern": {
                "type": "string",
                "description": "Regex pattern identifying the content to redact. Required when strategy is 'replace'."
              }
            }
          }
        },
        "transformation": {
          "type": "object",
          "description": "Field transformations when action is 'transform'. Keys are dot-notation field paths, values are template strings supporting {{field.path}} interpolation.",
          "additionalProperties": {
            "type": "string"
          }
        },
        "applies_to": {
          "type": "array",
          "description": "Interception points this policy applies to. Omit to apply to all points.",
          "items": {
            "type": "string",
            "enum": ["input", "output", "tool_call"]
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "tools": {
          "type": "array",
          "description": "Tool names this policy applies to. Only evaluated when applies_to includes 'tool_call'. Omit to apply to all tools.",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        }
      },
      "allOf": [
        {
          "if": { "properties": { "action": { "const": "transform" } } },
          "then": { "required": ["transformation"] }
        },
        {
          "if": { "properties": { "action": { "const": "redact" } } },
          "then": { "required": ["redactions"] }
        }
      ]
    },
    "Condition": {
      "description": "A condition evaluated against the context",
      "oneOf": [
        { "$ref": "#/$defs/EqualsCondition" },
        { "$ref": "#/$defs/ContainsCondition" },
        { "$ref": "#/$defs/NotInCondition" },
        { "$ref": "#/$defs/GreaterThanCondition" },
        { "$ref": "#/$defs/AlwaysCondition" }
      ]
    },
    "EqualsCondition": {
      "type": "object",
      "description": "Matches when the resolved field value strictly equals the operand",
      "required": ["field", "equals"],
      "additionalProperties": false,
      "properties": {
        "field": {
          "type": "string",
          "description": "Dot-notation path to the field in the context (e.g. 'tool_name', 'messages.0.content')"
        },
        "equals": {
          "description": "The value to compare against using strict equality"
        }
      }
    },
    "ContainsCondition": {
      "type": "object",
      "description": "Matches when the resolved field value contains any of the given substrings (case-insensitive)",
      "required": ["field", "contains"],
      "additionalProperties": false,
      "properties": {
        "field": { "type": "string" },
        "contains": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        }
      }
    },
    "NotInCondition": {
      "type": "object",
      "description": "Matches when the resolved field value is not present in the given list",
      "required": ["field", "not_in"],
      "additionalProperties": false,
      "properties": {
        "field": { "type": "string" },
        "not_in": {
          "type": "array",
          "description": "List of values the field must not be equal to"
        }
      }
    },
    "GreaterThanCondition": {
      "type": "object",
      "description": "Matches when the resolved field value is numerically greater than the operand",
      "required": ["field", "greater_than"],
      "additionalProperties": false,
      "properties": {
        "field": { "type": "string" },
        "greater_than": { "type": "number" }
      }
    },
    "AlwaysCondition": {
      "type": "object",
      "description": "Always matches, regardless of context",
      "required": ["always"],
      "additionalProperties": false,
      "properties": {
        "always": {
          "type": "boolean",
          "const": true
        }
      }
    }
  }
}
