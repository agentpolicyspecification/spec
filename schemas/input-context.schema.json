{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentpolicyspecification.github.io/schemas/input-context.schema.json",
  "title": "InputContext",
  "description": "The evaluation input provided to policies at the Input Interception point.",
  "type": "object",
  "required": ["messages", "metadata"],
  "additionalProperties": false,
  "properties": {
    "messages": {
      "type": "array",
      "description": "The ordered message history to be forwarded to the LLM runtime.",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/Message"
      }
    },
    "metadata": {
      "$ref": "#/$defs/Metadata"
    }
  },
  "$defs": {
    "Message": {
      "type": "object",
      "required": ["role", "content"],
      "additionalProperties": false,
      "properties": {
        "role": {
          "type": "string",
          "enum": ["system", "user", "assistant"],
          "description": "The role of the message author."
        },
        "content": {
          "type": "string",
          "description": "The text content of the message."
        }
      }
    },
    "Metadata": {
      "type": "object",
      "required": ["agent_id", "session_id", "timestamp"],
      "additionalProperties": true,
      "properties": {
        "agent_id": {
          "type": "string",
          "description": "Unique identifier for the agent sending the message."
        },
        "session_id": {
          "type": "string",
          "description": "Unique identifier for the current session."
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp of when the interception occurred."
        }
      }
    }
  }
}
